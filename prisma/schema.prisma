generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  avatar        String?
  role          String        @default("user")
  publisherStatus String?    @map("publisher_status")
  theme         String?       @default("system")
  accentColor   String?       @default("blue")           @map("accent_color")
  passwordHash  String?                                  @map("password_hash")
  googleId      String?       @unique                    @map("google_id")
  createdAt     DateTime      @default(now())            @map("created_at")
  updatedAt     DateTime      @updatedAt                 @map("updated_at")
  events        Event[]
  savedEvents   SavedEvent[]
  createdPodcasts RadioPodcast[]
  notifications   Notification[]

  @@map("users")
}

model Category {
  id             Int           @id @default(autoincrement())
  name           String
  slug           String        @unique
  icon           String?
  color          String?
  parentId       Int?                                    @map("parent_id")
  parent         Category?     @relation("CategoryParent", fields: [parentId], references: [id])
  children       Category[]    @relation("CategoryParent")
  events         Event[]
  scrapedSources ScrapedSource[]

  @@map("categories")
}

model Event {
  id              Int          @id @default(autoincrement())
  title           String
  slug            String?      @unique
  description     String?
  categoryId      Int?                                   @map("category_id")
  category        Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date            DateTime?
  endDate         DateTime?                              @map("end_date")
  time            String?
  timePeriod      String?                                @map("time_period")
  location        String?
  address         String?
  city            String?
  province        String?
  region          String?      @default("Lazio")
  price           String?
  suitableFor     String?                                @map("suitable_for")
  imageUrl        String?                                @map("image_url")
  sourceUrl       String?                                @map("source_url")
  sourceName      String?                                @map("source_name")
  isAutoGenerated Boolean      @default(false)           @map("is_auto_generated")
  isPublished     Boolean      @default(true)            @map("is_published")
  status          String       @default("approved")      // pending, approved, rejected
  createdBy       String?                                @map("created_by")
  creator         User?        @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  viewCount       Int          @default(0)               @map("view_count")
  createdAt       DateTime     @default(now())           @map("created_at")
  updatedAt       DateTime     @updatedAt                @map("updated_at")
  savedBy         SavedEvent[]
  notifications   Notification[]

  @@map("events")
}

model SavedEvent {
  userId  String                                        @map("user_id")
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId Int                                           @map("event_id")
  event   Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  savedAt DateTime  @default(now())                     @map("saved_at")

  @@id([userId, eventId])
  @@map("saved_events")
}

model SearchConfig {
  id                  Int             @id @default(autoincrement())
  name                String          @default("default")
  cities              String?
  provinces           String?
  categories          String?
  keywords            String?
  radiusKm            Int?                                @map("radius_km")
  autoScrape          Boolean         @default(false)     @map("auto_scrape")
  scrapeIntervalHours  Int?            @default(24)       @map("scrape_interval_hours")
  scrapedSources      ScrapedSource[]

  @@map("search_config")
}

model ScrapedSource {
  id               Int          @id @default(autoincrement())
  name             String
  url              String
  type             String       @default("html")
  isActive         Boolean      @default(true)               @map("is_active")
  selectors        String?
  city             String?
  province         String?
  categoryId       Int?                                      @map("category_id")
  category         Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  lastScrapedAt    DateTime?                                @map("last_scraped_at")
  configId         Int?                                      @map("config_id")
  config           SearchConfig? @relation(fields: [configId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())              @map("created_at")

  @@map("scraped_sources")
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId    Int?     @map("event_id")
  event      Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  type       String   // "upcoming_event" | "recommendation" | "general"
  title      String
  body       String?
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model Ad {
  id          Int      @id @default(autoincrement())
  title       String
  imageUrl    String   @map("image_url")
  linkUrl     String?  @map("link_url")
  placement   String   @default("sidebar")   // sidebar | banner | inline | footer
  size        String   @default("square")    // square | horizontal | vertical | leaderboard
  isActive    Boolean  @default(true)        @map("is_active")
  sortOrder   Int      @default(0)           @map("sort_order")
  startDate   DateTime?                       @map("start_date")
  endDate     DateTime?                       @map("end_date")
  clickCount  Int      @default(0)           @map("click_count")
  createdAt   DateTime @default(now())       @map("created_at")

  @@map("ads")
}

model Video {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  embedUrl    String   @map("embed_url")
  thumbnail   String?
  platform    String   @default("youtube") // youtube | vimeo | instagram | facebook | tiktok | other
  sortOrder   Int      @default(0)          @map("sort_order")
  isPublished Boolean  @default(true)       @map("is_published")
  createdAt   DateTime @default(now())      @map("created_at")

  @@map("videos")
}

model RadioSetting {
  id                  Int       @id @default(autoincrement())
  stationName         String?                            @map("station_name")
  stationDescription  String?                            @map("station_description")
  streamUrl           String?                            @map("stream_url")
  isLive              Boolean   @default(false)           @map("is_live")
  currentTrack        String?                            @map("current_track")
  updatedAt           DateTime  @updatedAt                @map("updated_at")

  @@map("radio_settings")
}

model RadioPodcast {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  filePath    String?                                    @map("file_path")
  duration    Int?
  fileSize    Int?                                       @map("file_size")
  fileType    String?                                    @map("file_type")
  isPublished Boolean  @default(true)                    @map("is_published")
  createdBy   String?                                    @map("created_by")
  creator     User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())                   @map("created_at")

  @@map("radio_podcasts")
}

model RadioLiveChunk {
  id         Int      @id @default(autoincrement())
  chunkData  String?                                    @map("chunk_data")
  chunkIndex Int?                                       @map("chunk_index")
  createdAt  DateTime @default(now())                    @map("created_at")

  @@map("radio_live_chunks")
}
