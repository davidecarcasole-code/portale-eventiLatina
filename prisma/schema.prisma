generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  avatar        String?
  role          String        @default("user")
  theme         String?       @default("system")
  accentColor   String?       @default("blue")
  passwordHash  String?
  googleId      String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  events        Event[]
  savedEvents   SavedEvent[]
  createdPodcasts RadioPodcast[]

  @@map("users")
}

model Category {
  id       Int         @id @default(autoincrement())
  name     String
  slug     String      @unique
  icon     String?
  color    String?
  parentId Int?
  parent   Category?   @relation("CategoryParent", fields: [parentId], references: [id])
  children       Category[]      @relation("CategoryParent")
  events         Event[]
  scrapedSources ScrapedSource[]

  @@map("categories")
}

model Event {
  id              Int          @id @default(autoincrement())
  title           String
  description     String?
  categoryId      Int?
  category        Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date            DateTime?
  endDate         DateTime?
  time            String?
  timePeriod      String?
  location        String?
  address         String?
  city            String?
  province        String?
  region          String?      @default("Lazio")
  price           String?
  suitableFor     String?
  imageUrl        String?
  sourceUrl       String?
  sourceName      String?
  isAutoGenerated Boolean      @default(false)
  isPublished     Boolean      @default(true)
  createdBy       String?
  creator         User?        @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  savedBy         SavedEvent[]

  @@map("events")
}

model SavedEvent {
  userId  String
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId Int
  event   Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  savedAt DateTime  @default(now())

  @@id([userId, eventId])
  @@map("saved_events")
}

model SearchConfig {
  id                 Int              @id @default(autoincrement())
  name               String           @default("default")
  cities             String?
  provinces          String?
  categories         String?
  keywords           String?
  radiusKm           Int?
  autoScrape         Boolean          @default(false)
  scrapeIntervalHours Int?            @default(24)
  scrapedSources     ScrapedSource[]

  @@map("search_config")
}

model ScrapedSource {
  id           Int          @id @default(autoincrement())
  name         String
  url          String
  type         String       @default("html")
  isActive     Boolean      @default(true)
  selectors    String?
  city         String?
  province     String?
  categoryId   Int?
  category     Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  lastScrapedAt DateTime?
  configId     Int?
  config       SearchConfig? @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("scraped_sources")
}

model RadioSetting {
  id                Int       @id @default(autoincrement())
  stationName       String?
  stationDescription String?
  streamUrl         String?
  isLive            Boolean   @default(false)
  currentTrack      String?
  updatedAt         DateTime  @updatedAt

  @@map("radio_settings")
}

model RadioPodcast {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  filePath    String?
  duration    Int?
  fileSize    Int?
  fileType    String?
  isPublished Boolean  @default(true)
  createdBy   String?
  creator     User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@map("radio_podcasts")
}

model RadioLiveChunk {
  id         Int      @id @default(autoincrement())
  chunkData  String?
  chunkIndex Int?
  createdAt  DateTime @default(now())

  @@map("radio_live_chunks")
}
